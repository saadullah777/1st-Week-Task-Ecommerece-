<header class="sticky top-0 bg-white border-b border-[#E5E5E5] z-50">
  <div class="max-w-screen-2xl mx-auto px-4 md:px-8 py-6">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="font-heading text-2xl md:text-3xl font-black tracking-tighter uppercase" data-testid="logo-link">
        STORE
      </a>
      
      <!-- Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="font-mono text-xs uppercase tracking-widest hover:text-accent transition-colors" data-testid="nav-home">Home</a>
        <a href="/products" class="font-mono text-xs uppercase tracking-widest hover:text-accent transition-colors" data-testid="nav-products">Products</a>
      </nav>
      
      <!-- Cart Icon -->
      <div class="flex items-center gap-4">
        <a href="/products" class="md:hidden font-mono text-xs uppercase tracking-widest" data-testid="nav-products-mobile">Products</a>
        <button class="p-2 hover:text-accent transition-colors" data-testid="cart-button">
          <i data-lucide="shopping-cart" class="w-6 h-6"></i>
        </button>
      </div>
    </div>
  </div>
</header>
