  <!-- Breadcrumb -->
  <div class="border-b border-[#E5E5E5]">
    <div class="max-w-screen-2xl mx-auto px-4 md:px-8 py-6">
      <nav class="flex items-center gap-2 text-sm" data-testid="breadcrumb">
        <a href="/" class="text-black/60 hover:text-accent transition-colors">Home</a>
        <span class="text-black/40">/</span>
        <a href="/products" class="text-black/60 hover:text-accent transition-colors">Products</a>
        <span class="text-black/40">/</span>
        <span class="text-black font-medium"><%= product.name %></span>
      </nav>
    </div>
  </div>
  
  <!-- Product Detail -->
  <section class="py-16 md:py-24">
    <div class="max-w-screen-2xl mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Product Image -->
        <div class="lg:sticky lg:top-24 h-fit">
          <div class="product-image-hover border border-[#E5E5E5]">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-auto" data-testid="product-detail-image">
          </div>
        </div>
        
        <!-- Product Info -->
        <div>
          <span class="bg-black text-white font-mono text-xs px-2 py-1 uppercase tracking-wider inline-block mb-4" data-testid="product-detail-category"><%= product.category %></span>
          
          <h1 class="font-heading text-4xl md:text-5xl font-black tracking-tighter uppercase mb-6" data-testid="product-detail-name"><%= product.name %></h1>
          
          <div class="flex items-baseline gap-4 mb-8 pb-8 border-b border-[#E5E5E5]">
            <span class="font-mono text-3xl font-bold tracking-tight" data-testid="product-detail-price">$<%= typeof product.price === 'number' ? product.price.toFixed(2) : product.price %></span>
            <span class="font-mono text-sm text-black/60" data-testid="product-detail-stock">
              <% if (product.stock > 0) { %>
                IN STOCK (<%= product.stock %> AVAILABLE)
              <% } else { %>
                OUT OF STOCK
              <% } %>
            </span>
          </div>
          
          <div class="mb-8">
            <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-black/60 mb-4">DESCRIPTION</h2>
            <p class="text-lg text-black/80 leading-relaxed" data-testid="product-detail-description"><%= product.description %></p>
          </div>
          
          <div class="mb-8">
            <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-black/60 mb-4">SPECIFICATIONS</h2>
            <dl class="grid grid-cols-2 gap-4">
              <div>
                <dt class="font-mono text-xs uppercase text-black/60 mb-1">Category</dt>
                <dd class="font-sans text-base" data-testid="spec-category"><%= product.category %></dd>
              </div>
              <div>
                <dt class="font-mono text-xs uppercase text-black/60 mb-1">Stock</dt>
                <dd class="font-sans text-base" data-testid="spec-stock"><%= product.stock %> units</dd>
              </div>
              <div>
                <dt class="font-mono text-xs uppercase text-black/60 mb-1">Product ID</dt>
                <dd class="font-mono text-sm" data-testid="spec-id"><%= product._id %></dd>
              </div>
              <div>
                <dt class="font-mono text-xs uppercase text-black/60 mb-1">Status</dt>
                <dd class="font-sans text-base" data-testid="spec-status">
                  <% if (product.stock > 0) { %>
                    <span class="text-green-600">Available</span>
                  <% } else { %>
                    <span class="text-red-600">Sold Out</span>
                  <% } %>
                </dd>
              </div>
            </dl>
          </div>
          
          <!-- Add to Cart -->
          <div class="flex flex-col md:flex-row gap-4 mb-12">
            <button class="bg-accent text-white font-mono uppercase tracking-widest text-sm py-4 px-8 hover:bg-accent-hover transition-colors flex-1" data-testid="add-to-cart-button">
              <i data-lucide="shopping-cart" class="inline-block w-4 h-4 mr-2"></i>
              ADD TO CART
            </button>
            <button class="border border-black bg-transparent text-black font-mono uppercase tracking-widest text-sm py-4 px-8 hover:bg-black hover:text-white transition-colors" data-testid="wishlist-button">
              <i data-lucide="heart" class="inline-block w-4 h-4"></i>
            </button>
          </div>
          
          <!-- Additional Info -->
          <div class="border-t border-[#E5E5E5] pt-8">
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <i data-lucide="truck" class="w-5 h-5 mt-1 text-black/60"></i>
                <div>
                  <h3 class="font-mono text-xs uppercase tracking-wider mb-1">FREE SHIPPING</h3>
                  <p class="text-sm text-black/60">On orders over $500</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <i data-lucide="refresh-cw" class="w-5 h-5 mt-1 text-black/60"></i>
                <div>
                  <h3 class="font-mono text-xs uppercase tracking-wider mb-1">30-DAY RETURNS</h3>
                  <p class="text-sm text-black/60">Hassle-free return policy</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <i data-lucide="shield-check" class="w-5 h-5 mt-1 text-black/60"></i>
                <div>
                  <h3 class="font-mono text-xs uppercase tracking-wider mb-1">WARRANTY</h3>
                  <p class="text-sm text-black/60">2-year manufacturer warranty</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Related Products -->
  <% if (relatedProducts.length > 0) { %>
  <section class="py-24 bg-[#F9F9F9] border-t border-[#E5E5E5]">
    <div class="max-w-screen-2xl mx-auto px-4 md:px-8">
      <h2 class="font-heading text-3xl md:text-4xl font-black tracking-tight uppercase mb-12">RELATED PRODUCTS</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-[#E5E5E5] border border-[#E5E5E5]">
        <% relatedProducts.forEach(relProduct => { %>
          <a href="/products/<%= relProduct._id %>" class="bg-white p-6 flex flex-col h-full group" data-testid="related-product-card">
            <div class="product-image-hover mb-4">
              <img src="<%= relProduct.image %>" alt="<%= relProduct.name %>" class="w-full h-48 object-cover" data-testid="related-product-image">
            </div>
            <span class="bg-black text-white font-mono text-xs px-2 py-1 uppercase tracking-wider inline-block mb-2 w-fit" data-testid="related-product-category"><%= relProduct.category %></span>
            <h3 class="font-sans text-base font-medium mb-2 group-hover:text-accent transition-colors" data-testid="related-product-name"><%= relProduct.name %></h3>
            <span class="font-mono text-base font-bold mt-auto" data-testid="related-product-price">$<%= typeof relProduct.price === 'number' ? relProduct.price.toFixed(2) : relProduct.price %></span>
          </a>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>
